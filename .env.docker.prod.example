# =============================================================================
# Docker Production Environment Configuration
# =============================================================================
# ⚠️  NEVER COMMIT THIS FILE TO GIT
# Generate strong secrets before deployment
#
# Usage:
#   cp .env.docker.prod.example .env.docker.prod
#   nano .env.docker.prod  # Edit with real production values
#   export $(cat .env.docker.prod | xargs)
#   docker-compose up -d

# === FastAPI Configuration ===
# Generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_32_CHAR_SECRET
ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30
APP_NAME=FastAPI Expense Tracker
APP_VERSION=1.0.0
DEBUG=false

# === Database Configuration ===
# Use strong credentials and secure network isolation
# Example for PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://app_user:STRONG_PASSWORD@db.internal:5432/expense_tracker
# For SQLite (not recommended for production):
DATABASE_URL=sqlite:///./services/data/expense_tracker.db

# === Redis Configuration ===
# Generate strong password: openssl rand -hex 32
REDIS_PASSWORD=REPLACE_WITH_STRONG_RANDOM_PASSWORD

# === Grafana Configuration ===
# Generate strong password: openssl rand -hex 32
GRAFANA_PASSWORD=REPLACE_WITH_STRONG_RANDOM_PASSWORD

# === Nginx Configuration ===
# Tune based on server capacity
NGINX_WORKER_PROCESSES=8
NGINX_WORKER_CONNECTIONS=2048

# === Logging ===
LOG_LEVEL=WARNING
LOG_FILE=./logs/app.jsonl

# === Optional: SSL/TLS Certificates ===
# Uncomment and update paths in nginx/nginx.conf
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem
