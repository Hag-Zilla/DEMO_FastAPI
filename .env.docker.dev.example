# =============================================================================
# Docker Development Environment Configuration
# =============================================================================
# This is a template file (.example). Copy to .env.docker.dev for testing.
# This tests the full architecture (Nginx, Redis, FastAPI) with development data

# === FastAPI Configuration ===
SECRET_KEY=dev-secret-key-for-testing-only-not-production
ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30
APP_NAME=FastAPI Expense Tracker
APP_VERSION=1.0.0
DEBUG=true

# === Database Configuration ===
DATABASE_URL=sqlite:///./data/expense_tracker.db
# Can test with PostgreSQL: DATABASE_URL=postgresql://user:pass@postgres:5432/app

# === Redis Configuration (Required for Docker deployment) ===
REDIS_PASSWORD=dev_redis_password_change_in_prod

# === Grafana Configuration ===
GRAFANA_PASSWORD=admin

# === Nginx Configuration ===
NGINX_WORKER_PROCESSES=2
NGINX_WORKER_CONNECTIONS=1024

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=./logs/app.jsonl

