# =============================================================================
# Development Environment Configuration (Local, without Docker)
# =============================================================================
# Copy this to .env for local development
# This config is for running FastAPI directly (make run), no Nginx/Redis needed

# === FastAPI Configuration ===
SECRET_KEY=your-super-secret-key-min-32-chars-required-here
ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30
APP_NAME=FastAPI Expense Tracker
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=local

# === Database Configuration ===
DATABASE_URL=sqlite:///./services/data/expense_tracker.db
# For testing with PostgreSQL locally:
# DATABASE_URL=postgresql://user:password@localhost:5432/expense_tracker

# === Optional: Redis (for testing rate limiting locally) ===
# Only needed if running slowapi limiter in memory or with local Redis
# REDIS_URL=redis://localhost:6379/0

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=./services/api/logs/app.jsonl

# === Optional: Sentry error tracking (disabled by default) ===
# SENTRY_DSN=https://<key>@sentry.io/<project_id>
